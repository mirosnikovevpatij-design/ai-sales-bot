# ===========================================
# Локальная разработка / сервер
# Скопируйте в .env и подставьте свои значения.
# Ключи API понадобятся для продакшена (см. КЛЮЧИ_И_НАСТРОЙКИ.md).
# ===========================================

PORT=3000

# База данных (локально — Docker Postgres на 5433)
DATABASE_URL="postgresql://ai_bot:ai_bot_password@localhost:5433/ai_sales_bot?schema=public"

# Redis (очередь init_queue, follow-up, напоминания). На сервере с нашим docker-compose — порт 6380
REDIS_HOST=localhost
REDIS_PORT=6379

# ---- amoCRM (Kommo) ----
# Поддомен: https://<AMOCRM_SUBDOMAIN>.amocrm.ru
AMOCRM_SUBDOMAIN=
# OAuth2 access token (обновлять по истечении срока)
AMOCRM_ACCESS_TOKEN=

# ---- WhatCRM / WhatsApp через amoCRM Chats API ----
# Отправка/приём идёт через amoCRM Chats API; WhatCRM — виджет в amoCRM.
# Доп. ключ WhatCRM (если нужен для статуса подключения):
# WHATCRM_API_KEY=

# ---- Calendly (слоты и создание встреч Zoom) ----
CALENDLY_API_TOKEN=
# UUID типа события (event type) для встреч
# CALENDLY_EVENT_TYPE_UUID=

# ---- LLM (ответы бота) ----
# Вариант 1: DeepSeek (приоритет, если задан)
DEEPSEEK_API_KEY=
# Вариант 2: OpenAI
OPENAI_API_KEY=
# Базовый URL OpenAI (если нужен другой эндпоинт):
# OPENAI_API_BASE=https://api.openai.com/v1

# ---- Admin Panel ----
# Секрет для JWT (придумайте длинную случайную строку)
JWT_SECRET=

# ---- Уведомления (SLA, алерты) ----
# Телефон руководителя для WhatsApp (формат +7...)
# SUPERVISOR_WHATSAPP=
# Telegram bot token для алертов (опционально)
# TELEGRAM_BOT_TOKEN=
# Telegram chat ID для алертов
# TELEGRAM_ALERT_CHAT_ID=

# ---- Рабочее время и очереди (без API можно не менять) ----
TIMEZONE=Asia/Almaty
SEND_WINDOW_START=09:00
SEND_WINDOW_END=21:00
WORK_DAYS=1,2,3,4,5,6
# Задержка init (секунды): минимум и максимум + джиттер
INIT_RATE_DELAY_MIN=5
INIT_RATE_DELAY_MAX=30
# Попыток отправки init до INIT_FAILED
INIT_MAX_ATTEMPTS=3
# Follow-up: шаг 1 — часы, шаги 2 и 3 — дни
FOLLOWUP_1_DELAY_HOURS=24
FOLLOWUP_2_DELAY_DAYS=3
FOLLOWUP_3_DELAY_DAYS=10
# SLA handoff: через сколько часов считать просроченным (уведомление руководителю — позже)
HANDOFF_SLA_HOURS=2
